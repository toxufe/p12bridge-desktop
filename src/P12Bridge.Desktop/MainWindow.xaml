<Window x:Class="P12Bridge.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="P12Bridge"
        Height="720"
        Width="1120"
        MinHeight="560"
        MinWidth="880"
        Background="#F4F6F8"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F4F6F8" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedPanelBrush" Color="#EEF2F6" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D9E1EA" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1663D6" />
        <SolidColorBrush x:Key="PrimarySoftBrush" Color="#E8F1FF" />
        <SolidColorBrush x:Key="TextBrush" Color="#172033" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#637083" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#16835D" />
        <SolidColorBrush x:Key="WarningBrush" Color="#986A00" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#101827" />
        <SolidColorBrush x:Key="SidebarMutedBrush" Color="#AAB4C3" />

        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource SidebarMutedBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Margin" Value="12,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Chrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,8">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#182235" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#20314F" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#395A92" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#0E55C2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#0B469E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="#D7DEE8" />
                                <Setter Property="Foreground" Value="#6E7B8D" />
                                <Setter Property="Opacity" Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource MutedPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ModulePageStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="18,20,18,18">
                    <TextBlock Text="P12Bridge"
                               Foreground="#FFFFFF"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Windows iOS 工具"
                               Foreground="{StaticResource SidebarMutedBrush}"
                               FontSize="12"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="16">
                    <Border Background="#182235"
                            BorderBrush="#263A5C"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="本地优先"
                                       Foreground="#FFFFFF"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="私钥留本机"
                                       Foreground="{StaticResource SidebarMutedBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel>
                    <RadioButton x:Name="DashboardNav"
                                 Content="工作台"
                                 GroupName="MainNavigation"
                                 IsChecked="True"
                                 Tag="Dashboard"
                                 Checked="OnNavigationChecked"
                                 Style="{StaticResource NavButtonStyle}" />
                    <RadioButton Content="制作证书"
                                 GroupName="MainNavigation"
                                 Tag="Certificate"
                                 Checked="OnNavigationChecked"
                                 Style="{StaticResource NavButtonStyle}" />
                    <RadioButton Content="描述文件"
                                 GroupName="MainNavigation"
                                 Tag="Profiles"
                                 Checked="OnNavigationChecked"
                                 Style="{StaticResource NavButtonStyle}" />
                    <RadioButton Content="IPA 检查"
                                 GroupName="MainNavigation"
                                 Tag="IpaCheck"
                                 Checked="OnNavigationChecked"
                                 Style="{StaticResource NavButtonStyle}" />
                    <RadioButton Content="IPA 上传"
                                 GroupName="MainNavigation"
                                 Tag="Upload"
                                 Checked="OnNavigationChecked"
                                 Style="{StaticResource NavButtonStyle}" />
                    <RadioButton Content="资产库"
                                 GroupName="MainNavigation"
                                 Tag="Assets"
                                 Checked="OnNavigationChecked"
                                 Style="{StaticResource NavButtonStyle}" />
                    <RadioButton Content="设置"
                                 GroupName="MainNavigation"
                                 Tag="Settings"
                                 Checked="OnNavigationChecked"
                                 Style="{StaticResource NavButtonStyle}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="28,24,28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="PageTitleText"
                               Text="工作台"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="PageSubtitleText"
                               Text="证书到上传总览"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="13"
                               Margin="0,5,0,0" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{StaticResource PrimarySoftBrush}"
                        BorderBrush="#C8DDFF"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,8"
                        VerticalAlignment="Center">
                    <TextBlock Text="本地版"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>

            <Grid Grid.Row="1">
                <ScrollViewer x:Name="DashboardPage" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="1. 制作证书"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="15" />
                                    <TextBlock Text="生成私钥与 CSR"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,14" />
                                    <Button Content="进入"
                                            Tag="Certificate"
                                            Click="OnModuleShortcutClick"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="2. 描述文件"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="15" />
                                    <TextBlock Text="导入描述文件"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,14" />
                                    <Button Content="进入"
                                            Tag="Profiles"
                                            Click="OnModuleShortcutClick"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="3. IPA 检查"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="15" />
                                    <TextBlock Text="读取版本与签名"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,14" />
                                    <Button Content="进入"
                                            Tag="IpaCheck"
                                            Click="OnModuleShortcutClick"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3" Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="4. IPA 上传"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="15" />
                                    <TextBlock Text="上传构建包"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,14" />
                                    <Button Content="进入"
                                            Tag="Upload"
                                            Click="OnModuleShortcutClick"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="能力状态"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <Grid Margin="0,12,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="34" />
                                            <RowDefinition Height="34" />
                                            <RowDefinition Height="34" />
                                            <RowDefinition Height="34" />
                                            <RowDefinition Height="34" />
                                            <RowDefinition Height="34" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.25*" />
                                            <ColumnDefinition Width="0.75*" />
                                            <ColumnDefinition Width="1.4*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Text="私钥 / CSR / P12" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="可导出" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="P12 就绪" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />

                                        <TextBlock Grid.Row="1" Text="描述文件解析" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="可解析" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="字段就绪" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />

                                        <TextBlock Grid.Row="2" Text="IPA 元数据" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="可读取" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="元数据就绪" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />

                                        <TextBlock Grid.Row="3" Text="上传前检查" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="可校验" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="3" Grid.Column="2" Text="规则就绪" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />

                                        <TextBlock Grid.Row="4" Text="API Key / JWT" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="可认证" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="4" Grid.Column="2" Text="令牌就绪" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />

                                        <TextBlock Grid.Row="5" Text="上传服务" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="可调用" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="5" Grid.Column="2" Text="上传就绪" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="安全边界"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <StackPanel Margin="0,12,0,16">
                                        <TextBlock Text="不收主密码"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="13" />
                                        <TextBlock Text="凭据不自动保存"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="13"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                    <Button Content="查看设置"
                                            Tag="Settings"
                                            Click="OnModuleShortcutClick"
                                            Style="{StaticResource ActionButtonStyle}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <Grid x:Name="CertificatePage" Style="{StaticResource ModulePageStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.25*" />
                                <ColumnDefinition Width="0.9*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0" VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="新建证书"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />

                                    <Grid Margin="0,16,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Text="项目名" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox x:Name="CertificateProjectNameTextBox"
                                                     Style="{StaticResource InputTextBoxStyle}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="2">
                                            <TextBlock Text="类型" Style="{StaticResource FieldLabelStyle}" />
                                            <ComboBox x:Name="CertificatePurposeComboBox"
                                                      Style="{StaticResource InputComboBoxStyle}"
                                                      SelectedIndex="1">
                                                <ComboBoxItem Content="开发" />
                                                <ComboBoxItem Content="发布" />
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,12,0,0">
                                            <TextBlock Text="名称" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox x:Name="CertificateCommonNameTextBox"
                                                     Style="{StaticResource InputTextBoxStyle}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,12,0,0">
                                            <TextBlock Text="邮箱" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox x:Name="CertificateEmailTextBox"
                                                     Style="{StaticResource InputTextBoxStyle}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,12,0,0">
                                            <TextBlock Text="组织" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox x:Name="CertificateOrganizationTextBox"
                                                     Style="{StaticResource InputTextBoxStyle}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,12,0,0">
                                            <TextBlock Text="国家" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox x:Name="CertificateCountryTextBox"
                                                     Text="CN"
                                                     MaxLength="2"
                                                     Style="{StaticResource InputTextBoxStyle}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="3" Grid.ColumnSpan="3" Margin="0,12,0,0">
                                            <TextBlock Text="目录" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox x:Name="CertificateBaseDirectoryTextBox"
                                                     Style="{StaticResource InputTextBoxStyle}" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                        <Button Content="生成"
                                                Click="OnCreateCertificateProjectClick"
                                                Style="{StaticResource ActionButtonStyle}" />
                                        <Button x:Name="OpenCertificateProjectButton"
                                                Content="打开"
                                                Click="OnOpenCertificateProjectClick"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="10,0,0,0"
                                                IsEnabled="False" />
                                    </StackPanel>

                                    <TextBlock x:Name="CertificateStatusText"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               Margin="0,14,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="生成结果"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />

                                    <TextBlock Text="项目目录" Style="{StaticResource FieldLabelStyle}" Margin="0,16,0,5" />
                                    <TextBox x:Name="CertificateProjectDirectoryTextBox"
                                             Style="{StaticResource InputTextBoxStyle}"
                                             IsReadOnly="True" />

                                    <TextBlock Text="私钥" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,5" />
                                    <TextBox x:Name="CertificatePrivateKeyPathTextBox"
                                             Style="{StaticResource InputTextBoxStyle}"
                                             IsReadOnly="True" />

                                    <TextBlock Text="CSR" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,5" />
                                    <TextBox x:Name="CertificateCsrPathTextBox"
                                             Style="{StaticResource InputTextBoxStyle}"
                                             IsReadOnly="True" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="ProfilesPage" Style="{StaticResource ModulePageStyle}">
                    <Border Style="{StaticResource CardBorderStyle}" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="描述文件"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Bundle、Team、有效期"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,16" />
                            <Button Content="导入文件"
                                    Style="{StaticResource ActionButtonStyle}"
                                    HorizontalAlignment="Left"
                                    IsEnabled="False" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="IpaCheckPage" Style="{StaticResource ModulePageStyle}">
                    <Border Style="{StaticResource CardBorderStyle}" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="IPA 检查"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="版本、签名、阻断项"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,16" />
                            <Button Content="选择 IPA"
                                    Style="{StaticResource ActionButtonStyle}"
                                    HorizontalAlignment="Left"
                                    IsEnabled="False" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="UploadPage" Style="{StaticResource ModulePageStyle}">
                    <Border Style="{StaticResource CardBorderStyle}" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="IPA 上传"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="进度、日志、结果"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,16" />
                            <Button Content="准备上传"
                                    Style="{StaticResource ActionButtonStyle}"
                                    HorizontalAlignment="Left"
                                    IsEnabled="False" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="AssetsPage" Style="{StaticResource ModulePageStyle}">
                    <Border Style="{StaticResource CardBorderStyle}" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="资产库"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="项目、备份、历史"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,16" />
                            <Button Content="打开目录"
                                    Style="{StaticResource ActionButtonStyle}"
                                    HorizontalAlignment="Left"
                                    IsEnabled="False" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="SettingsPage" Style="{StaticResource ModulePageStyle}">
                    <Border Style="{StaticResource CardBorderStyle}" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="设置"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="凭据、路径、隐私"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,16" />
                            <Button Content="配置"
                                    Style="{StaticResource ActionButtonStyle}"
                                    HorizontalAlignment="Left"
                                    IsEnabled="False" />
                        </StackPanel>
                    </Border>
                </Grid>
