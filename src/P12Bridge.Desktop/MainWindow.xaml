<Window x:Class="P12Bridge.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="P12Bridge"
        Height="720"
        Width="1120"
        MinHeight="560"
        MinWidth="880"
        Background="#F4F6F8"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F4F6F8" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedPanelBrush" Color="#EEF2F6" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D9E1EA" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1663D6" />
        <SolidColorBrush x:Key="PrimarySoftBrush" Color="#E8F1FF" />
        <SolidColorBrush x:Key="TextBrush" Color="#172033" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#637083" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#16835D" />
        <SolidColorBrush x:Key="WarningBrush" Color="#986A00" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B42318" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#101827" />
        <SolidColorBrush x:Key="SidebarMutedBrush" Color="#AAB4C3" />

        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource SidebarMutedBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Margin" Value="12,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Chrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,8">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#182235" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#20314F" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#395A92" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#0E55C2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#0B469E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="#D7DEE8" />
                                <Setter Property="Foreground" Value="#6E7B8D" />
                                <Setter Property="Opacity" Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource MutedPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ModulePageStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="18,20,18,18">
                    <TextBlock Text="P12Bridge"
                               Foreground="#FFFFFF"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Windows iOS 工具"
                               Foreground="{StaticResource SidebarMutedBrush}"
                               FontSize="12"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="16">
                    <Border Background="#182235"
                            BorderBrush="#263A5C"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="本地优先"
                                       Foreground="#FFFFFF"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="私钥留本机"
                                       Foreground="{StaticResource SidebarMutedBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel>
                    <RadioButton x:Name="DashboardNav"
                                 Content="工作台"
                                 GroupName="MainNavigation"
                                 IsChecked="True"
                                 Tag="Dashboard"
                                 Checked="OnNavigationChecked"
                                 Style="{StaticResource NavButtonStyle}" />
                    <RadioButton Content="制作证书"
                                 GroupName="MainNavigation"
                                 Tag="Certificate"
                                 Checked="OnNavigationChecked"
                                 Style="{StaticResource NavButtonStyle}" />
                    <RadioButton Content="描述文件"
                                 GroupName="MainNavigation"
                                 Tag="Profiles"
                                 Checked="OnNavigationChecked"
                                 Style="{StaticResource NavButtonStyle}" />
                    <RadioButton Content="IPA 检查"
                                 GroupName="MainNavigation"
                                 Tag="IpaCheck"
                                 Checked="OnNavigationChecked"
                                 Style="{StaticResource NavButtonStyle}" />
                    <RadioButton Content="IPA 上传"
                                 GroupName="MainNavigation"
                                 Tag="Upload"
                                 Checked="OnNavigationChecked"
                                 Style="{StaticResource NavButtonStyle}" />
                    <RadioButton Content="资产库"
                                 GroupName="MainNavigation"
                                 Tag="Assets"
                                 Checked="OnNavigationChecked"
                                 Style="{StaticResource NavButtonStyle}" />
                    <RadioButton Content="历史"
                                 GroupName="MainNavigation"
                                 Tag="History"
                                 Checked="OnNavigationChecked"
                                 Style="{StaticResource NavButtonStyle}" />
                    <RadioButton Content="设置"
                                 GroupName="MainNavigation"
                                 Tag="Settings"
                                 Checked="OnNavigationChecked"
                                 Style="{StaticResource NavButtonStyle}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="28,24,28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="PageTitleText"
                               Text="工作台"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="PageSubtitleText"
                               Text="证书到上传总览"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="13"
                               Margin="0,5,0,0" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{StaticResource PrimarySoftBrush}"
                        BorderBrush="#C8DDFF"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,8"
                        VerticalAlignment="Center">
                    <TextBlock Text="本地版"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>

            <Grid Grid.Row="1">
                <ScrollViewer x:Name="DashboardPage" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="1. 制作证书"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="15" />
                                    <TextBlock Text="生成私钥与 CSR"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,14" />
                                    <Button Content="进入"
                                            Tag="Certificate"
                                            Click="OnModuleShortcutClick"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="2. 描述文件"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="15" />
                                    <TextBlock Text="导入描述文件"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,14" />
                                    <Button Content="进入"
                                            Tag="Profiles"
                                            Click="OnModuleShortcutClick"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="3. IPA 检查"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="15" />
                                    <TextBlock Text="读取版本与签名"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,14" />
                                    <Button Content="进入"
                                            Tag="IpaCheck"
                                            Click="OnModuleShortcutClick"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3" Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="4. IPA 上传"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="15" />
                                    <TextBlock Text="上传前检查"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,14" />
                                    <Button Content="进入"
                                            Tag="Upload"
                                            Click="OnModuleShortcutClick"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="能力状态"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <Grid Margin="0,12,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="34" />
                                            <RowDefinition Height="34" />
                                            <RowDefinition Height="34" />
                                            <RowDefinition Height="34" />
                                            <RowDefinition Height="34" />
                                            <RowDefinition Height="34" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.25*" />
                                            <ColumnDefinition Width="0.75*" />
                                            <ColumnDefinition Width="1.4*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Text="私钥 / CSR / P12" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="可导出" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="P12 就绪" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />

                                        <TextBlock Grid.Row="1" Text="描述文件解析" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="可解析" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="字段就绪" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />

                                        <TextBlock Grid.Row="2" Text="IPA 元数据" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="可读取" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="元数据就绪" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />

                                        <TextBlock Grid.Row="3" Text="上传前检查" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="可校验" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="3" Grid.Column="2" Text="规则就绪" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />

                                        <TextBlock Grid.Row="4" Text="API Key / JWT" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="可认证" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="4" Grid.Column="2" Text="令牌就绪" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />

                                        <TextBlock Grid.Row="5" Text="上传服务" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="可调用" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="5" Grid.Column="2" Text="上传就绪" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="本地资产"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="DashboardAssetTotalText"
                                               Text="0 项"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Margin="0,10,0,0" />
                                    <TextBlock x:Name="DashboardAssetCountsText"
                                               Text="证书 0 / 描述 0 / IPA 0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="13"
                                               Margin="0,4,0,16" />
                                    <Button Content="资产库"
                                            Tag="Assets"
                                            Click="OnModuleShortcutClick"
                                            Style="{StaticResource ActionButtonStyle}" />
                                    <Border BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="0,1,0,0"
                                            Margin="0,16,0,0"
                                            Padding="0,14,0,0">
                                        <StackPanel>
                                            <TextBlock Text="到期提醒"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <TextBlock x:Name="DashboardExpirationSummaryText"
                                                       Text="暂无提醒"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="13"
                                                       Margin="0,8,0,0" />
                                            <TextBlock x:Name="DashboardExpirationCountsText"
                                                       Text="过期 0 / 临期 0"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="13"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="最近资产"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="DashboardRecentAssetsStatusText"
                                           Text="暂无资产"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="13"
                                           Margin="0,8,0,12" />

                                <ListBox x:Name="DashboardRecentAssetsListBox"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         MinHeight="72">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F8FAFC"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10"
                                                    Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="84" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="150" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding TypeText}"
                                                               Foreground="{StaticResource PrimaryBrush}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Note}"
                                                                   Visibility="{Binding NoteVisibility}"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,4,0,0" />
                                                        <TextBlock Text="{Binding ArtifactText}"
                                                                   Visibility="{Binding ArtifactVisibility}"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,4,0,0" />
                                                        <TextBlock Text="{Binding SafeMetadataSummary}"
                                                                   Visibility="{Binding SafeMetadataSummaryVisibility}"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,4,0,0" />
                                                        <TextBlock Text="{Binding BackupSummary}"
                                                                   Visibility="{Binding BackupSummaryVisibility}"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,4,0,0" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding ModifiedText}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               FontSize="12"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,18,0,0">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="最近操作"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock x:Name="DashboardRecentHistoryStatusText"
                                                   Text="暂无记录"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="13"
                                                   Margin="0,8,0,12" />
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="全部"
                                            Tag="History"
                                            Click="OnModuleShortcutClick"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            VerticalAlignment="Top" />
                                </Grid>

                                <ListBox x:Name="DashboardRecentHistoryListBox"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         MinHeight="72">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F8FAFC"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10"
                                                    Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="82" />
                                                        <ColumnDefinition Width="96" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="112" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding StatusText}"
                                                               Foreground="{Binding StatusBrush}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Operation}"
                                                               Foreground="{StaticResource TextBrush}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Summary}"
                                                               Foreground="{StaticResource TextBrush}"
                                                               FontSize="13"
                                                               TextWrapping="Wrap"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding TimeText}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               FontSize="12"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid x:Name="CertificatePage" Style="{StaticResource ModulePageStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.25*" />
                                <ColumnDefinition Width="0.9*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0" VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="新建证书"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />

                                    <Grid Margin="0,16,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Text="项目名" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox x:Name="CertificateProjectNameTextBox"
                                                     Style="{StaticResource InputTextBoxStyle}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="2">
                                            <TextBlock Text="类型" Style="{StaticResource FieldLabelStyle}" />
                                            <ComboBox x:Name="CertificatePurposeComboBox"
                                                      Style="{StaticResource InputComboBoxStyle}"
                                                      SelectedIndex="1">
