                                                 MinHeight="280"
                                                 Margin="0,12,0,0"
                                                 VerticalContentAlignment="Top"
                                                 VerticalScrollBarVisibility="Auto"
                                                 TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Grid>

