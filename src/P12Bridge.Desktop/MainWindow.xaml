                                                    <Border Background="#F8FAFC"
                                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="10"
                                                            Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="88" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="130" />
                                                            </Grid.ColumnDefinitions>
